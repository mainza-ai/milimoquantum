# =============================================================================
# Milimo Quantum - Environment Configuration Example
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# =============================================================================
# Authentication
# =============================================================================
AUTH_ENABLED=true

# =============================================================================
# Database Configuration (Docker)
# =============================================================================
DATABASE_URL=postgresql://milimo:milimopassword@localhost:5432/milimoquantum

# =============================================================================
# Redis Configuration (Celery Broker)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# Neo4j Graph Database
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# LLM Backend Configuration
# =============================================================================
# Options: mlx, ollama, openai, anthropic, google
LLM_BACKEND=mlx

# Ollama (local)
OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Quantum Cloud Providers (Optional)
# =============================================================================
# IBM Quantum - Get token from: https://quantum-computing.ibm.com/
# IBM_QUANTUM_TOKEN=your_ibm_token_here

# D-Wave - Get API key from: https://cloud.dwavesys.com/
# DWAVE_API_KEY=your_dwave_key_here

# Amazon Braket
# AWS_BRAKET_REGION=us-east-1
# AWS_BRAKET_BUCKET=your-s3-bucket

# =============================================================================
# NVIDIA NIM API (Optional - for cloud inference)
# =============================================================================
# Get your API key from: https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your_key_here

# =============================================================================
# External Data Feeds (Optional)
# =============================================================================
# Telegram Bot (for notifications)
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# =============================================================================
# Simulation Mode
# =============================================================================
# Set to true for local-only execution (no cloud backends)
SIM_ONLY_MODE=true

# =============================================================================
# Project Paths (Optional - auto-detected if not set)
# =============================================================================
# AUTORESEARCH_DIR=/path/to/milimoquantum/autoresearch-mlx
# MILIMO_PYTHON=/path/to/milimoquantum/backend/milimoenv/bin/python
# PROJECT_ROOT=/path/to/milimoquantum
